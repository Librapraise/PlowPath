NODE_ENV=development
PORT=3000

POSTGRES_USER=plowpath
POSTGRES_PASSWORD=plowpath
POSTGRES_DB=plowpath

DATABASE_URL=postgresql://plowpath:plowpath@localhost:5432/plowpath
REDIS_URL=redis://localhost:6379

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-me-with-a-256-bit-random-string
JWT_EXPIRES_IN=12h
JWT_REFRESH_EXPIRES_IN=30d

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173

# Nominatim (OSM) — User-Agent is required by their fair-use policy.
NOMINATIM_USER_AGENT=PlowPath/1.0
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# OSRM public router (fair-use). Self-host for production.
OSRM_BASE_URL=https://router.project-osrm.org

# NO GOOGLE_MAPS_API_KEY — cost-optimized architecture forbids it.

# Twilio (Phase 3 — leave blank for now)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Firebase (Phase 3 — leave blank for now)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Database Seeding Custom Credentials (optional, secure random values generated if left blank)
SEED_ADMIN_EMAIL=admin@plowpath.local
SEED_ADMIN_PASSWORD=
SEED_DRIVER_PASSWORD=
SEED_ADMIN_PHONE=+15550000000
SEED_DRIVER1_PHONE=+15551110001
SEED_DRIVER2_PHONE=+15551110002
